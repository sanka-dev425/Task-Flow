{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "dotnet publish src/TaskFlow.Api/TaskFlow.Api.csproj -c Release -o /app/out"
  },
  "deploy": {
    "startCommand": "dotnet /app/out/TaskFlow.Api.dll --urls http://0.0.0.0:${PORT:-5000}",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
